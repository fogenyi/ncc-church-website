<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-hands-helping me-2 text-accent"></i>Parish Ministries</h1>
  <hr class="section-divider" style="margin-left:0;">
  <p class="text-muted">Our ministries provide opportunities to live out your faith through service, worship, and community. Find your calling and volunteer today.</p>
</div>

<div class="row g-4">
  <!-- Liturgy Ministry -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-church"></i>
        </div>
        <h5 class="card-title">Liturgy Ministry</h5>
        <p class="card-text text-muted">Serve at the altar as lectors, Extraordinary Ministers of Holy Communion, altar servers, or ushers. Help create a prayerful and welcoming liturgical environment for all parishioners.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Altar Servers (ages 10+)</li>
          <li><i class="fas fa-check text-success me-2"></i>Lectors &amp; Readers</li>
          <li><i class="fas fa-check text-success me-2"></i>Eucharistic Ministers</li>
          <li><i class="fas fa-check text-success me-2"></i>Ushers &amp; Greeters</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>

  <!-- Music Ministry -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-music"></i>
        </div>
        <h5 class="card-title">Music Ministry</h5>
        <p class="card-text text-muted">Enhance worship through song and music. Our parish has multiple choirs and instrumental ensembles that perform at Masses throughout the week. All skill levels welcome.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Adult Choir (Sunday)</li>
          <li><i class="fas fa-check text-success me-2"></i>Youth Choir</li>
          <li><i class="fas fa-check text-success me-2"></i>Contemporary Ensemble</li>
          <li><i class="fas fa-check text-success me-2"></i>Cantors</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>

  <!-- Social Justice / Outreach -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-balance-scale"></i>
        </div>
        <h5 class="card-title">Outreach &amp; Social Justice</h5>
        <p class="card-text text-muted">Live out the Gospel call to serve the poor and marginalized. We operate food pantries, visit homebound parishioners, and advocate for justice in our community.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Food Pantry Volunteers</li>
          <li><i class="fas fa-check text-success me-2"></i>Hospital Visitation</li>
          <li><i class="fas fa-check text-success me-2"></i>Homeless Outreach</li>
          <li><i class="fas fa-check text-success me-2"></i>Advocacy &amp; Education</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>

  <!-- Religious Education (CCD) -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-graduation-cap"></i>
        </div>
        <h5 class="card-title">Religious Education (CCD)</h5>
        <p class="card-text text-muted">Our CCD program provides faith formation for children from 1st through 8th grade. Dedicated catechists guide children on their spiritual journey and sacramental preparation.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Grades 1–8 Classes</li>
          <li><i class="fas fa-check text-success me-2"></i>First Communion Prep</li>
          <li><i class="fas fa-check text-success me-2"></i>Confirmation Prep</li>
          <li><i class="fas fa-check text-success me-2"></i>Catechist Volunteers</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>

  <!-- RCIA -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-water"></i>
        </div>
        <h5 class="card-title">RCIA Ministry</h5>
        <p class="card-text text-muted">The Rite of Christian Initiation of Adults welcomes those who wish to become Catholic or complete their sacraments. Our team accompanies each inquirer with care and prayer.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Inquiry Sessions</li>
          <li><i class="fas fa-check text-success me-2"></i>Catechumenate</li>
          <li><i class="fas fa-check text-success me-2"></i>Easter Vigil Sacraments</li>
          <li><i class="fas fa-check text-success me-2"></i>Sponsor Volunteers</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>

  <!-- Bereavement Ministry -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-dove"></i>
        </div>
        <h5 class="card-title">Bereavement Ministry</h5>
        <p class="card-text text-muted">Walk alongside families who have lost loved ones by offering comfort, prayer, meal coordination, and funeral Mass support. A ministry of compassion and presence.</p>
        <ul class="list-unstyled text-muted small mb-3 text-start">
          <li><i class="fas fa-check text-success me-2"></i>Funeral Mass Support</li>
          <li><i class="fas fa-check text-success me-2"></i>Grief Support Groups</li>
          <li><i class="fas fa-check text-success me-2"></i>Meal Coordination</li>
          <li><i class="fas fa-check text-success me-2"></i>Pastoral Visits</li>
        </ul>
        <a href="/more" class="btn btn-primary-custom btn-sm">
          <i class="fas fa-hand-paper me-1"></i>Volunteer
        </a>
      </div>
    </div>
  </div>
</div>

<div class="mt-5 p-4 rounded-3 text-center" style="background: linear-gradient(135deg, var(--primary), var(--primary-light)); color:#fff;">
  <h4 class="mb-2">Ready to Serve?</h4>
  <p class="mb-3 opacity-75">Contact us to learn more about volunteering in any of our ministries.</p>
  <a href="/more" class="btn btn-hero-outline">
    <i class="fas fa-envelope me-1"></i>Get in Touch
  </a>
</div>
