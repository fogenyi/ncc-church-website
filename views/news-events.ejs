  <div class="row g-3">
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <span class="badge bg-primary mb-2">News</span>
          <h6 class="card-title">Bishop Visits NCC Parish</h6>
          <p class="card-text text-muted small">His Excellency Bishop Thomas Carey visited our parish to celebrate the Feast of Corpus Christi with our community.</p>
          <a href="/news" class="btn btn-sm btn-outline-primary">Read More</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <span class="badge bg-success mb-2">Event Recap</span>
          <h6 class="card-title">Spring Parish Picnic</h6>
          <p class="card-text text-muted small">Over 300 parishioners gathered for our annual spring picnic — a day of food, fun, and community spirit.</p>
          <a href="/gallery" class="btn btn-sm btn-outline-primary">View Photos</a>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card">
        <div class="card-body">
          <span class="badge bg-warning text-dark mb-2">Upcoming</span>
