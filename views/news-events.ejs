<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-newspaper me-2 text-accent"></i>News &amp; Events</h1>
  <hr class="section-divider" style="margin-left:0;">
  <p class="text-muted">Stay connected with everything happening at NCC Parish.</p>
</div>

<div class="row g-4 mt-2">
  <div class="col-md-6">
    <div class="card h-100 text-center p-4">
      <div class="card-body">
        <div class="ministry-icon mx-auto mb-3">
          <i class="fas fa-newspaper"></i>
        </div>
        <h3 class="card-title h4 fw-bold text-primary-custom">Parish News</h3>
        <p class="card-text text-muted">Read the latest news, weekly bulletins, and parish announcements. Stay informed about what's happening in our community.</p>
        <ul class="list-unstyled text-muted small text-start mb-4">
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Weekly Parish Bulletin</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Pastor's Corner</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Community Announcements</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Diocesan News</li>
        </ul>
        <a href="/news" class="btn btn-primary-custom">
          <i class="fas fa-arrow-right me-1"></i>Read Latest News
        </a>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card h-100 text-center p-4">
      <div class="card-body">
        <div class="ministry-icon mx-auto mb-3" style="background-color: var(--accent);">
          <i class="fas fa-calendar-alt"></i>
        </div>
        <h3 class="card-title h4 fw-bold" style="color: var(--accent);">Upcoming Events</h3>
        <p class="card-text text-muted">Browse our events calendar for upcoming Masses, retreats, community gatherings, and special celebrations throughout the year.</p>
        <ul class="list-unstyled text-muted small text-start mb-4">
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Parish Retreats &amp; Missions</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Community Gatherings</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Youth &amp; Family Events</li>
          <li class="mb-1"><i class="fas fa-check-circle text-success me-2"></i>Liturgical Celebrations</li>
        </ul>
        <a href="/events" class="btn btn-accent">
          <i class="fas fa-arrow-right me-1"></i>View All Events
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Recent Highlights -->
<section class="mt-5">
