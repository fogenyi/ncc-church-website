<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-images me-2 text-accent"></i>Photo Gallery</h1>
  <hr class="section-divider" style="margin-left:0;">
  <p class="text-muted">Browse photos from parish events, liturgy, and community life at NCC Parish.</p>
</div>

<!-- Category Filter -->
<div class="mb-4 d-flex flex-wrap gap-2">
  <button class="btn btn-primary-custom btn-sm">All Photos</button>
  <button class="btn btn-outline-secondary btn-sm">Parish Events</button>
  <button class="btn btn-outline-secondary btn-sm">Community</button>
  <button class="btn btn-outline-secondary btn-sm">Liturgy</button>
  <button class="btn btn-outline-secondary btn-sm">Youth</button>
</div>

<!-- Gallery Grid -->
<div class="gallery-grid">
  <div class="gallery-item" tabindex="0" role="button" aria-label="View photo: Parish Picnic 2025">
    <img src="https://via.placeholder.com/400x300/1a3a5c/ffffff?text=Parish+Picnic+2025" alt="Parish Picnic 2025" loading="lazy">
    <div class="gallery-overlay"><i class="fas fa-search-plus"></i></div>
  </div>
  <div class="gallery-item" tabindex="0" role="button" aria-label="View photo: Sunday Mass">
