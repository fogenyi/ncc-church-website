<!-- Request Form -->
<section>
  <h2 class="h5 fw-bold text-primary-custom mb-3">
    <i class="fas fa-edit me-2"></i>Request a Mass Intention
  </h2>
  <div class="card">
    <div class="card-body">
      <p class="text-muted small mb-4">
        <i class="fas fa-info-circle me-1"></i>
        Mass intention offerings are $10 per Mass. Please contact the parish office to arrange payment after submitting your request.
      </p>
      <form class="needs-validation" novalidate>
        <div class="row g-3">
          <div class="col-md-6">
            <label for="requesterName" class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="requesterName" placeholder="Your full name" required>
            <div class="invalid-feedback">Please enter your name.</div>
          </div>
          <div class="col-md-6">
            <label for="requesterEmail" class="form-label fw-semibold">Your Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="requesterEmail" placeholder="you@email.com" required>
            <div class="invalid-feedback">Please enter a valid email.</div>
          </div>
          <div class="col-md-6">
            <label for="intentionName" class="form-label fw-semibold">Name for Intention <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="intentionName" placeholder="Name of person" required>
            <div class="invalid-feedback">Please enter the name for the intention.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-semibold">Type of Intention <span class="text-danger">*</span></label>
            <div class="d-flex gap-4 mt-1">
              <div class="form-check">
                <input class="form-check-input" type="radio" name="intentionType" id="typeLiving" value="living" required>
                <label class="form-check-label" for="typeLiving">Living</label>
              </div>
              <div class="form-check">
                <input class="form-check-input" type="radio" name="intentionType" id="typeDeceased" value="deceased">
                <label class="form-check-label" for="typeDeceased">Deceased (R.I.P.)</label>
              </div>
            </div>
          </div>
          <div class="col-md-6">
            <label for="preferredDate" class="form-label fw-semibold">Preferred Date</label>
            <input type="date" class="form-control" id="preferredDate">
          </div>
          <div class="col-md-6">
            <label for="preferredMass" class="form-label fw-semibold">Preferred Mass Time</label>
            <select class="form-select" id="preferredMass">
              <option value="">Any available</option>
              <option>Sunday 8:00 AM</option>
              <option>Sunday 10:00 AM</option>
              <option>Sunday 12:00 PM</option>
              <option>Weekday 7:00 AM</option>
              <option>Saturday 5:30 PM (Vigil)</option>
            </select>
          </div>
          <div class="col-12">
            <label for="intentionMessage" class="form-label fw-semibold">Additional Message</label>
            <textarea class="form-control" id="intentionMessage" rows="3" placeholder="Any additional details or special requests..."></textarea>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary-custom">
              <i class="fas fa-paper-plane me-1"></i>Submit Request
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>
