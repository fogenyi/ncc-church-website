<!-- Hero Section -->
<div class="hero-section">
  <div class="container position-relative">
    <i class="fas fa-cross fa-2x mb-3" style="color: var(--gold);"></i>
    <h1 class="mb-3">Welcome to NCC Parish</h1>
    <p class="lead mb-4">A welcoming Catholic community rooted in faith, service, and fellowship.<br>All are welcome at the table of the Lord.</p>
