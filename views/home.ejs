</div>

<!-- Mass Schedule -->
<section class="mass-schedule-section">
  <div class="container">
    <h2 class="section-title text-center">Mass Schedule</h2>
    <hr class="section-divider">
    <div class="row g-4">
      <div class="col-md-4">
        <div class="mass-card">
          <div class="day-label"><i class="fas fa-sun me-1"></i>Sunday</div>
          <div class="time-label mt-1">8:00 AM &bull; 10:00 AM &bull; 12:00 PM</div>
          <p class="text-muted mb-0 mt-1 small">Main Celebratory Masses</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mass-card">
          <div class="day-label"><i class="fas fa-calendar-alt me-1"></i>Monday – Friday</div>
          <div class="time-label mt-1">7:00 AM</div>
          <p class="text-muted mb-0 mt-1 small">Daily Morning Mass</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="mass-card">
          <div class="day-label"><i class="fas fa-moon me-1"></i>Saturday (Vigil)</div>
          <div class="time-label mt-1">5:30 PM</div>
          <p class="text-muted mb-0 mt-1 small">Saturday Vigil Mass</p>
        </div>
      </div>
    </div>
    <p class="text-center mt-3 mb-0">
      <a href="/mass-intentions" class="btn btn-sm btn-primary-custom">
        <i class="fas fa-pray me-1"></i>Request a Mass Intention
      </a>
    </p>
  </div>
</section>

<!-- Announcements -->
<section class="py-5">
  <h2 class="section-title text-center">Latest Announcements</h2>
  <hr class="section-divider">
  <div class="row g-4">
    <div class="col-md-4">
      <div class="card announcement-card h-100">
        <div class="card-body">
          <span class="badge bg-warning text-dark mb-2">Important</span>
          <h5 class="card-title">Annual Parish Retreat</h5>
          <p class="card-text text-muted">Our annual parish retreat will be held July 14–16 at the Diocesan Conference Center. All parishioners are encouraged to attend.</p>
          <small class="text-muted"><i class="fas fa-calendar me-1"></i>June 30, 2026</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card announcement-card h-100">
        <div class="card-body">
          <span class="badge bg-primary mb-2">Community</span>
          <h5 class="card-title">New RCIA Program Begins</h5>
          <p class="card-text text-muted">Our RCIA journey begins this September. If you or someone you know is interested in becoming Catholic, please contact the parish office.</p>
          <small class="text-muted"><i class="fas fa-calendar me-1"></i>June 25, 2026</small>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="card announcement-card h-100">
        <div class="card-body">
          <span class="badge bg-success mb-2">Service</span>
          <h5 class="card-title">Food Drive – July</h5>
          <p class="card-text text-muted">Help us support our local food bank. Drop off non-perishable items in the collection bins at the church entrance throughout July.</p>
          <small class="text-muted"><i class="fas fa-calendar me-1"></i>June 20, 2026</small>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- About Snippet -->
<section class="py-5 bg-light rounded-3 px-4 mb-4">
  <div class="row align-items-center g-4">
    <div class="col-md-7">
      <h2 class="section-title">About NCC Parish</h2>
      <hr class="section-divider" style="margin-left:0;">
      <p class="lead">Founded in 1952, NCC Parish has been a cornerstone of faith and community for over 70 years.</p>
      <p class="text-muted">We are a diverse, vibrant Catholic community committed to worship, education, and outreach. Our doors are open to all who seek the Lord, and we welcome everyone into our parish family.</p>
      <a href="/about" class="btn btn-primary-custom mt-2">
        <i class="fas fa-info-circle me-1"></i>Learn More About Us
      </a>
    </div>
    <div class="col-md-5 text-center">
      <div class="rounded-3 overflow-hidden shadow" style="background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%); height:220px; display:flex; align-items:center; justify-content:center;">
        <i class="fas fa-church" style="font-size:6rem; color: rgba(255,255,255,0.3);"></i>
      </div>
    </div>
  </div>
</section>

