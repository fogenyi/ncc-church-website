          </div>
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:rgba(26,58,92,0.1);">
            <i class="fas fa-users" style="color: var(--primary);"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 col-sm-6">
    <div class="card admin-stat-card accent h-100">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start">
