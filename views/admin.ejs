        <div class="d-flex justify-content-between align-items-start">
          <div>
            <p class="text-muted small fw-semibold text-uppercase mb-1" style="letter-spacing:0.07em;">News Articles</p>
            <div class="admin-stat-number">24</div>
            <p class="text-muted small mt-1 mb-0"><i class="fas fa-newspaper me-1" style="color:var(--gold);"></i>4 this month</p>
          </div>
          <div class="rounded-circle d-flex align-items-center justify-content-center" style="width:50px;height:50px;background:rgba(212,160,23,0.1);">
            <i class="fas fa-newspaper" style="color: var(--gold);"></i>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="col-md-3 col-sm-6">
