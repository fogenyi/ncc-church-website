<!-- Admin Header -->
<div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
  <div>
    <h1 class="section-title mb-0"><i class="fas fa-tachometer-alt me-2 text-accent"></i>Admin Dashboard</h1>
    <p class="text-muted mb-0">Welcome back! Here's what's happening at NCC Parish.</p>
  </div>
  <span class="badge bg-warning text-dark fs-6 px-3 py-2">
    <i class="fas fa-exclamation-triangle me-1"></i>Demo Mode – No Auth
  </span>
</div>

<!-- Stat Cards -->
<div class="row g-4 mb-5">
  <div class="col-md-3 col-sm-6">
