<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-id-card me-2 text-accent"></i>Join Our Parish</h1>
  <hr class="section-divider" style="margin-left:0;">
  <p class="text-muted">Become a registered member of NCC Parish and be part of our growing community of faith.</p>
</div>

<!-- Benefits -->
<section class="mb-5">
  <h2 class="h5 fw-bold text-primary-custom mb-3">Benefits of Parish Membership</h2>
  <div class="row g-3">
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Sacramental Preparation</strong>
          <p class="text-muted small mb-0">Access to Baptism, First Communion, Confirmation, and Marriage preparation programs.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Community &amp; Fellowship</strong>
          <p class="text-muted small mb-0">Connect with hundreds of families through groups, events, and shared faith.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Pastoral Support</strong>
          <p class="text-muted small mb-0">Access to our clergy and counseling resources in times of need.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Envelope &amp; Giving</strong>
          <p class="text-muted small mb-0">Receive weekly envelopes and access to online giving for convenient stewardship.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Parish Bulletin</strong>
          <p class="text-muted small mb-0">Receive the weekly bulletin by email or pick one up at Sunday Mass.</p>
        </div>
      </div>
    </div>
    <div class="col-md-4">
      <div class="d-flex gap-3 align-items-start">
        <i class="fas fa-check-circle fa-lg mt-1" style="color: var(--accent);"></i>
        <div>
          <strong>Ministry Involvement</strong>
          <p class="text-muted small mb-0">Serve in our ministries and help build the Kingdom of God in our community.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Registration Form -->
<section>
  <h2 class="h5 fw-bold text-primary-custom mb-3">
    <i class="fas fa-user-plus me-2"></i>Parish Registration Form
  </h2>
  <div class="card">
    <div class="card-body">
      <form class="needs-validation" novalidate>
        <!-- Personal Info -->
        <h6 class="fw-bold text-muted text-uppercase mb-3 mt-1" style="letter-spacing:0.08em; font-size:0.78rem;">
          <i class="fas fa-user me-1"></i>Personal Information
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <label for="firstName" class="form-label fw-semibold">First Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="firstName" required>
            <div class="invalid-feedback">Required.</div>
          </div>
          <div class="col-md-4">
            <label for="lastName" class="form-label fw-semibold">Last Name <span class="text-danger">*</span></label>
            <input type="text" class="form-control" id="lastName" required>
            <div class="invalid-feedback">Required.</div>
          </div>
          <div class="col-md-4">
            <label for="dob" class="form-label fw-semibold">Date of Birth</label>
            <input type="date" class="form-control" id="dob">
          </div>
          <div class="col-md-6">
            <label for="memberEmail" class="form-label fw-semibold">Email <span class="text-danger">*</span></label>
            <input type="email" class="form-control" id="memberEmail" required>
            <div class="invalid-feedback">Please enter a valid email.</div>
          </div>
          <div class="col-md-6">
            <label for="phone" class="form-label fw-semibold">Phone Number</label>
            <input type="tel" class="form-control" id="phone" placeholder="(555) 000-0000">
          </div>
        </div>

        <!-- Address -->
        <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing:0.08em; font-size:0.78rem;">
          <i class="fas fa-home me-1"></i>Home Address
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-12">
            <label for="address" class="form-label fw-semibold">Street Address</label>
            <input type="text" class="form-control" id="address" placeholder="123 Main St">
          </div>
          <div class="col-md-5">
            <label for="city" class="form-label fw-semibold">City</label>
            <input type="text" class="form-control" id="city">
          </div>
          <div class="col-md-4">
            <label for="state" class="form-label fw-semibold">State</label>
            <select class="form-select" id="state">
              <option value="">Select...</option>
              <option>AL</option><option>AK</option><option>AZ</option><option>AR</option><option>CA</option>
              <option>CO</option><option>CT</option><option>DE</option><option>FL</option><option>GA</option>
              <option>HI</option><option>ID</option><option>IL</option><option>IN</option><option>IA</option>
              <option>KS</option><option>KY</option><option>LA</option><option>ME</option><option>MD</option>
              <option>MA</option><option>MI</option><option>MN</option><option>MS</option><option>MO</option>
              <option>MT</option><option>NE</option><option>NV</option><option>NH</option><option>NJ</option>
              <option>NM</option><option>NY</option><option>NC</option><option>ND</option><option>OH</option>
              <option>OK</option><option>OR</option><option>PA</option><option>RI</option><option>SC</option>
              <option>SD</option><option>TN</option><option>TX</option><option>UT</option><option>VT</option>
              <option>VA</option><option>WA</option><option>WV</option><option>WI</option><option>WY</option>
            </select>
          </div>
          <div class="col-md-3">
            <label for="zip" class="form-label fw-semibold">ZIP Code</label>
            <input type="text" class="form-control" id="zip" placeholder="00000">
          </div>
        </div>

        <!-- Sacramental Status -->
        <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing:0.08em; font-size:0.78rem;">
          <i class="fas fa-cross me-1"></i>Sacramental &amp; Family Status
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-4">
            <label for="baptism" class="form-label fw-semibold">Baptism Status</label>
            <select class="form-select" id="baptism">
              <option value="">Select...</option>
              <option>Baptized Catholic</option>
              <option>Baptized Non-Catholic</option>
              <option>Not Baptized</option>
            </select>
          </div>
          <div class="col-md-4">
            <label for="confirmation" class="form-label fw-semibold">Confirmation Status</label>
            <select class="form-select" id="confirmation">
              <option value="">Select...</option>
              <option>Confirmed</option>
              <option>Not Yet Confirmed</option>
              <option>N/A</option>
            </select>
          </div>
          <div class="col-md-4">
            <label for="maritalStatus" class="form-label fw-semibold">Marital Status</label>
            <select class="form-select" id="maritalStatus">
              <option value="">Select...</option>
              <option>Single</option>
              <option>Married</option>
              <option>Widowed</option>
              <option>Divorced</option>
              <option>Separated</option>
            </select>
          </div>
        </div>

        <!-- Emergency Contact -->
        <h6 class="fw-bold text-muted text-uppercase mb-3" style="letter-spacing:0.08em; font-size:0.78rem;">
          <i class="fas fa-phone-alt me-1"></i>Emergency Contact
        </h6>
        <div class="row g-3 mb-4">
          <div class="col-md-6">
            <label for="emergencyName" class="form-label fw-semibold">Contact Name</label>
            <input type="text" class="form-control" id="emergencyName">
          </div>
          <div class="col-md-6">
            <label for="emergencyPhone" class="form-label fw-semibold">Contact Phone</label>
            <input type="tel" class="form-control" id="emergencyPhone" placeholder="(555) 000-0000">
          </div>
        </div>

        <div class="form-check mb-4">
          <input class="form-check-input" type="checkbox" id="agreeTerms" required>
          <label class="form-check-label" for="agreeTerms">
            I agree to receive parish communications and newsletters.
          </label>
          <div class="invalid-feedback">You must agree to proceed.</div>
        </div>

        <button type="submit" class="btn btn-primary-custom btn-lg">
          <i class="fas fa-user-plus me-2"></i>Submit Registration
        </button>
      </form>
    </div>
  </div>
</section>
