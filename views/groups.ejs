<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-users me-2 text-accent"></i>Parish Groups</h1>
  <hr class="section-divider" style="margin-left:0;">
  <p class="text-muted">Join a parish group and grow in faith together. There is a place for everyone in our community.</p>
</div>

<div class="row g-4">
  <!-- Prayer Group -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-pray"></i>
        </div>
        <h5 class="card-title">Prayer Group</h5>
        <p class="card-text text-muted">Gather weekly to pray the Rosary, Divine Mercy Chaplet, and intercessory prayers. Open to all parishioners every Tuesday at 7:00 PM in the Chapel.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>

  <!-- Youth Ministry -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-child"></i>
        </div>
        <h5 class="card-title">Youth Ministry</h5>
        <p class="card-text text-muted">For teens and young adults aged 13–25. We meet every Friday evening for fellowship, service projects, and faith discussions guided by Fr. Michael Brown.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>

  <!-- Bible Study -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-book-open"></i>
        </div>
        <h5 class="card-title">Bible Study</h5>
        <p class="card-text text-muted">Dive deeper into the Word of God. Our Bible Study group meets every Wednesday at 6:30 PM in the Parish Hall. All are welcome — no prior experience needed.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>

  <!-- Women's Guild -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-female"></i>
        </div>
        <h5 class="card-title">Women's Guild</h5>
        <p class="card-text text-muted">The NCC Women's Guild promotes spiritual growth, fellowship, and charitable work among women of the parish. Monthly meetings and annual retreats offered.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>

  <!-- Men's Fellowship -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-male"></i>
        </div>
        <h5 class="card-title">Men's Fellowship</h5>
        <p class="card-text text-muted">Men of all ages are invited to gather monthly for prayer, fellowship, and discussion on living as faithful Catholic men. Meetings held on the first Saturday at 8:00 AM.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>

  <!-- Senior Circle -->
  <div class="col-md-4">
    <div class="card h-100 text-center">
      <div class="card-body pt-4">
        <div class="ministry-icon">
          <i class="fas fa-heart"></i>
        </div>
        <h5 class="card-title">Senior Circle</h5>
        <p class="card-text text-muted">Our Senior Circle offers companionship, monthly luncheons, outings, and spiritual support for parishioners aged 60 and above. Everyone deserves community.</p>
        <a href="/membership" class="btn btn-primary-custom btn-sm mt-2">
          <i class="fas fa-plus-circle me-1"></i>Join Group
        </a>
      </div>
    </div>
  </div>
</div>

<div class="alert mt-5" style="background-color: rgba(26,58,92,0.08); border-left: 4px solid var(--primary);">
  <i class="fas fa-info-circle me-2 text-primary-custom"></i>
  Interested in starting a new group? <a href="/more" class="fw-bold">Contact the parish office</a> to discuss your idea with our pastoral team.
</div>
