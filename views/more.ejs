<div class="mb-4">
  <h1 class="section-title"><i class="fas fa-ellipsis-h me-2 text-accent"></i>Contact &amp; More</h1>
  <hr class="section-divider" style="margin-left:0;">
</div>

<div class="row g-5">
  <!-- Contact Form -->
  <div class="col-lg-7">
    <h2 class="h5 fw-bold text-primary-custom mb-3">
      <i class="fas fa-envelope me-2"></i>Send Us a Message
    </h2>
    <div class="card">
      <div class="card-body">
        <form class="needs-validation" novalidate>
          <div class="row g-3">
            <div class="col-md-6">
              <label for="contactName" class="form-label fw-semibold">Your Name <span class="text-danger">*</span></label>
              <input type="text" class="form-control" id="contactName" required>
              <div class="invalid-feedback">Please enter your name.</div>
            </div>
            <div class="col-md-6">
              <label for="contactEmail" class="form-label fw-semibold">Your Email <span class="text-danger">*</span></label>
              <input type="email" class="form-control" id="contactEmail" required>
              <div class="invalid-feedback">Please enter a valid email.</div>
            </div>
            <div class="col-12">
              <label for="contactSubject" class="form-label fw-semibold">Subject <span class="text-danger">*</span></label>
              <select class="form-select" id="contactSubject" required>
                <option value="">Select a subject...</option>
                <option>General Inquiry</option>
                <option>Sacramental Preparation</option>
                <option>Mass Intentions</option>
                <option>Ministry Volunteering</option>
                <option>Membership Registration</option>
                <option>Facility Rental</option>
                <option>Prayer Request</option>
                <option>Other</option>
              </select>
              <div class="invalid-feedback">Please select a subject.</div>
            </div>
            <div class="col-12">
              <label for="contactMessage" class="form-label fw-semibold">Message <span class="text-danger">*</span></label>
              <textarea class="form-control" id="contactMessage" rows="5" placeholder="How can we help you?" required></textarea>
              <div class="invalid-feedback">Please enter a message.</div>
            </div>
            <div class="col-12">
              <button type="submit" class="btn btn-primary-custom">
                <i class="fas fa-paper-plane me-1"></i>Send Message
              </button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Contact Info -->
  <div class="col-lg-5">
    <h2 class="h5 fw-bold text-primary-custom mb-3">
      <i class="fas fa-info-circle me-2"></i>Parish Information
    </h2>
    <div class="contact-info-box mb-4">
      <p class="mb-2"><i class="fas fa-map-marker-alt me-2 text-warning"></i><strong>Address</strong></p>
      <p class="mb-3 ms-4">123 Parish Lane<br>Cityville, ST 00000</p>
      <p class="mb-2"><i class="fas fa-phone me-2 text-warning"></i><strong>Phone</strong></p>
      <p class="mb-3 ms-4">(555) 123-4567</p>
      <p class="mb-2"><i class="fas fa-envelope me-2 text-warning"></i><strong>Email</strong></p>
      <p class="mb-3 ms-4"><a href="mailto:info@nccparish.org">info@nccparish.org</a></p>
      <p class="mb-2"><i class="fas fa-clock me-2 text-warning"></i><strong>Office Hours</strong></p>
      <p class="mb-0 ms-4">
        Mon–Fri: 9:00 AM – 5:00 PM<br>
        Saturday: 10:00 AM – 2:00 PM<br>
        Sunday: After all Masses
      </p>
    </div>

    <!-- Social Media -->
    <h2 class="h5 fw-bold text-primary-custom mb-3">
      <i class="fas fa-share-alt me-2"></i>Follow Us
    </h2>
    <div class="d-flex gap-3 mb-4">
      <a href="#" class="btn btn-primary" style="background:#1877f2; border-color:#1877f2;">
        <i class="fab fa-facebook-f me-1"></i>Facebook
      </a>
      <a href="#" class="btn" style="background:#ff0000; border-color:#ff0000; color:#fff;">
        <i class="fab fa-youtube me-1"></i>YouTube
      </a>
      <a href="#" class="btn" style="background:#1da1f2; border-color:#1da1f2; color:#fff;">
        <i class="fab fa-twitter me-1"></i>Twitter
      </a>
    </div>

    <!-- Catholic Resources -->
    <h2 class="h5 fw-bold text-primary-custom mb-3">
      <i class="fas fa-link me-2"></i>Catholic Resources
    </h2>
    <ul class="list-group">
      <li class="list-group-item">
        <a href="https://www.usccb.org" target="_blank" rel="noopener noreferrer" class="d-flex justify-content-between align-items-center text-decoration-none">
          <span><i class="fas fa-external-link-alt text-muted me-2"></i>USCCB (Bishops' Conference)</span>
          <i class="fas fa-chevron-right text-muted"></i>
        </a>
      </li>
      <li class="list-group-item">
        <a href="https://www.vatican.va" target="_blank" rel="noopener noreferrer" class="d-flex justify-content-between align-items-center text-decoration-none">
          <span><i class="fas fa-external-link-alt text-muted me-2"></i>The Vatican</span>
