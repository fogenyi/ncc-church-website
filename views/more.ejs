          <i class="fas fa-chevron-right text-muted"></i>
        </a>
      </li>
      <li class="list-group-item">
        <a href="https://formed.org" target="_blank" rel="noopener noreferrer" class="d-flex justify-content-between align-items-center text-decoration-none">
          <span><i class="fas fa-external-link-alt text-muted me-2"></i>FORMED Catholic Content</span>
          <i class="fas fa-chevron-right text-muted"></i>
        </a>
      </li>
    </ul>
  </div>
</div>
